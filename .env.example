# Токен Telegram-бота от @BotFather
BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# Telegram ID администраторов через запятую (узнать через /my_id в боте)
ADMIN_TELEGRAM_IDS=PASTE_ADMIN_TELEGRAM_ID_HERE

# Ссылка на Telegram менеджера
MANAGER_URL=https://t.me/PASTE_MANAGER_USERNAME_HERE

# Локальная база данных SQLite
# Для Railway будет автоматически подставлен DATABASE_URL от PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Уровень логирования
LOG_LEVEL=INFO
